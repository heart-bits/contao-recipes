688C4.74322 4.5179 4.84874 4.4741 4.94727 4.41699L5.04395 4.35547C5.20879 4.23875 5.34495 4.08376 5.4375 3.90137V3.90039L7.01172 0.791992L7.01074 0.791016C7.04336 0.727256 7.09113 0.67063 7.14844 0.624023L7.20898 0.581055C7.29275 0.530376 7.39021 0.501853 7.49023 0.5L7.58691 0.506836Z" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                    {% endif %}
                                {% endfor %}
                            {% endblock rating %}
                            {% block categories %}
                                {% if recipe.categories is not empty %}
                                    <div class="categories">
                                        {% for category in recipe.categories %}
                                            <span class="category category_{{ category.alias }}">{{ category.title }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                            {% endblock categories %}
                            {% block time %}
                                {% if recipe.time > 0 %}<span class="recipe-time">{{ recipe.time }}</span>{% endif %}
                            {% endblock time %}
                            {% block teaser %}
                                {% if recipe.teaser is defined and recipe.teaser %}{% with {'text': recipe.teaser} %}{{ block('rich_text_component') }}{% endwith %}{% endif %}
                            {% endblock teaser %}
                            {% block link %}
                                {% if recipe.jumpTo and recipe.hasContent %}<a href="{{ recipe.jumpTo }}">Zur Detailseite</a>{% endif %}
                            {% endblock link %}
                        </div>
                    {% endblock info %}
                </div>
            {% endfor %}
        {% endblock recipe %}
    {% else %}
        <p>{{ message }}</p>
    {% endif %}
{% endblock content %}
