{% extends "@Contao/content_element/_base.html.twig" %}
{% use "@Contao/component/_figure.html.twig" %}
{% use "@Contao/component/_rich_text.html.twig" %}

{% block text_media %}
    {% if recipe.singleSRC is defined and recipe.singleSRC %}
        <div class="recipe-image">
            {% with {figure: figure(recipe.singleSRC, size)} %}{{ block('figure_component') }}{% endwith %}
        </div>
    {% endif %}
{% endblock %}

{% block content %}
    {% if recipes is not empty %}
        {% block recipe %}
            {% for recipe in recipes %}
                <div class="recipe">
                    {{ block('text_media') }}
                    {% block info %}
                        <div class="recipe-info">
                            {% block title %}
                                <h3>{{ recipe.title }}</h3>
                                {% if recipe.subheadline %}<span class="subheadline">{{ recipe.subheadline }}</span>{% endif %}
                            {% endblock title %}
