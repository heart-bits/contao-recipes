{% extends "@Contao/content_element/_base.html.twig" %}
{% use "@Contao/component/_figure.html.twig" %}
{% use "@Contao/component/_rich_text.html.twig" %}
{% use '@Contao/component/_stylesheet.html.twig' %}

{% block text_media %}
    {% if recipe.singleSRC is defined and recipe.singleSRC %}
        <div class="recipe-image">
            {% with {figure: figure(recipe.singleSRC, size)} %}{{ block('figure_component') }}{% endwith %}
        </div>
    {% endif %}
{% endblock text_media %}

{% block content %}
    {% if text %}
        <div class="rte">
            {{ text | raw }}
        </div>
    {% endif %}
    {% if recipes is not empty %}
        {% if addRecipeFilter %}
            {% include '@Contao/components/recipe_filter.html.twig' with { 'categories': categories, 'ingredients': ingredients } only %}
        {% endif %}
        <div class="recipes">
            {% if addRecipeFilter %}
                <p id="filter-status" role="status" aria-live="polite"></p>
            {% endif %}
            <div id="recipe-list" class="recipe-list">
                {% block recipe %}
                    {% for recipe in recipes %}
                        <div class="recipe"{% if recipe.categories is not empty %} data-categories="{% for i, category in recipe.categories %}{% if i != 0 %},{% endif %}{{ category.alias }}{% endfor %}"{% endif %}{% if recipe.ingredients is not empty %} data-ingredients="{% for i, ingredient in recipe.ingredients %}{% if i != 0 %},{% endif %}{{ ingredient.alias }}{% endfor %}"{% endif %}>
                            {{ block('text_media') }}
                            {% block info %}
                                <div class="recipe-info">
                                    {% block title %}
                                        <h3 class="recipe-title">{{ recipe.title }}</h3>
                                        {% if recipe.subheadline %}<span class="recipe-subtitle">{{ recipe.subheadline }}</span>{% endif %}
                                    {% endblock title %}
                                    {% block rating %}
                                        <div class="recipe-rating">
                                            {% for i in 0..5 %}
                                                {% if i == 0 %}{% elseif i <= recipe.rating %}{{ source('@heartbitscontaorecipes' ~ (asset('img/star.svg'))) }}{% else %}{{ source('@heartbitscontaorecipes' ~ (asset('img/starOutlined.svg'))) }}{% endif %}
                                            {% endfor %}
                                        </div>
                                    {% endblock rating %}
                                    {% block categories %}
                                        {% if recipe.categories is not empty %}
                                            <div class="recipe-categories">
                                                {% for category in recipe.categories %}
                                                    <span class="recipe-category category_{{ category.alias }}">{{ category.title }}</span>
                                                {% endfor %}
                                            </div>
                                        {% endif %}
                                    {% endblock categories %}
                                    {% block time %}
                                        {% if recipe.time > 0 %}<span class="recipe-time">{{ recipe.time }} Min.</span>{% endif %}
                                    {% endblock time %}
                                    {% block teaser %}
                                        {% if recipe.teaser is defined and recipe.teaser %}{% with {'text': recipe.teaser} %}{{ block('rich_text_component') }}{% endwith %}{% endif %}
                                    {% endblock teaser %}
                                    {% block link %}
                                        {% if recipe.jumpTo and recipe.hasContent %}<a class="recipe-link" href="{{ recipe.jumpTo }}">Zur Detailseite</a>{% endif %}
                                    {% endblock link %}
                                </div>
                            {% endblock info %}
                        </div>
                    {% endfor %}
                {% endblock recipe %}
            </div>
        </div>
    {% else %}
        <p>{{ message }}</p>
    {% endif %}
{% endblock content %}

{% block script %}
    {% if addRecipeFilter %}
        {% add 'recipe_filter_js' to head %}
            {% set script_attributes = attrs()
                .setIfExists('nonce', csp_nonce('script-src'))
                .mergeWith(script_attributes|default)
            %}
            <script src="{{ asset('bundles/heartbitscontaorecipes/js/RecipeFilter.min.js') }}"></script>
            <script{{ script_attributes }}>
              document.addEventListener("DOMContentLoaded", () => {
                new RecipeFilter({
                  listSelector: "#recipe-list",
                  itemSelector: ".recipe",
                  categoryAttr: "categories",
                  ingredientAttr: "ingredients",
                  statusSelector: "#filter-status",
                  noResultsSelector: "#no-results",
                  formSelector: "#recipe-filters",
                  resetButtonSelector: "#reset-filters",
                  sheetSelector: "#recipe-filter-sheet",
                  openButtonSelector: "#filter-toggle",
                  closeButtonSelector: "#filter-close",
                  chipsSelector: "#active-filters",
                  urlCategoryParam: "category",
                  urlIngredientParam: "ingredient",
                  statusText: "{count} von {total} Rezepten werden angezeigt",
                  statusFiltered: "gefiltert",
                });
              });
            </script>
        {% endadd %}
    {% endif %}
{% endblock script %}

{% block style %}
    {% if addRecipeFilter %}
        {% add 'heartbits_contao_recipes_css' to stylesheets %}
            {% with {file: heartbits_contao_recipes_css_file|default(asset('bundles/heartbitscontaorecipes/css/contaoRecipes.min.css'))} %}
                {{ block('stylesheet_component') }}
            {% endwith %}
        {% endadd %}
    {% endif %}
{% endblock style %}
